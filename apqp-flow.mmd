---
config:
  theme: base
  themeVariables:
    primaryColor: "#1a3550"
    primaryTextColor: "#fff"
    primaryBorderColor: "#c4a24e"
    lineColor: "#5a6070"
    secondaryColor: "#f7f8fa"
    tertiaryColor: "#fff8e1"
---
flowchart TB
    PDF["📄 OEM 规格书 PDF（英/德文）"]

    subgraph S1["阶段1 · 文档清点与确认"]
        direction LR
        AI1["🤖 AI\n读取全文 · 识别层级\n⚠️ 找缺失文档和冲突\n🔍 自查引用覆盖"]
        H1["👤 人\n确认缺失：补or不补\n确认冲突：以谁为准"]
        O1["📄 工作底稿\n+ 确认报告"]
        AI1 --> H1 --> O1
    end

    subgraph S2["阶段2 · L1 工程特性提取（系统级）"]
        direction LR
        AI2["🤖 AI\n逐章提特性 · C/A分类\n⚠️ 标冲突 · 汇总缺口\n🔍 自查提取完整性"]
        H2["👤 人\n审核清单\n补充行业经验"]
        O2["📄 L1 特性清单\n含缺口与冲突"]
        AI2 --> H2 --> O2
    end

    subgraph S3["阶段3 · L2 零部件特性提取"]
        direction LR
        AI3["🤖 AI\n推断BOM · L1→L2分解\n⚠️ 标缺口\n🔍 自查分解完整性"]
        H3["👤 人\n审核BOM结构\n补充供应商经验"]
        O3["📄 L2 特性清单\n含缺口"]
        AI3 --> H3 --> O3
    end

    subgraph S4["阶段4 · QFD 质量屋矩阵"]
        direction LR
        AI4["🤖 AI\n构建L1×L2关联矩阵\n⚠️ 标关联强度 ◎○△\n🔍 自查空行/列/覆盖率\n📚 回写知识库"]
        H4["👤 人\n审核关联关系\n最终确认"]
        O4["📄 QFD 矩阵\n含审查结果"]
        AI4 --> H4 --> O4
    end

    DONE["✅ 全套交付物就绪，直接用于客审"]

    PDF --> S1 --> S2 --> S3 --> S4 --> DONE

    classDef inputNode fill:#0b1d32,stroke:#c4a24e,color:#fff,font-weight:bold
    classDef doneNode fill:#27ae60,stroke:#1e8449,color:#fff,font-weight:bold
    classDef outputNode fill:#fff8e1,stroke:#c4a24e,color:#1a2030,font-weight:bold

    class PDF inputNode
    class DONE doneNode
    class O1,O2,O3,O4 outputNode
